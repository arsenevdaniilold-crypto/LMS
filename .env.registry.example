# Environment for docker-compose.registry.yml (prebuilt images from Docker Hub).
# Copy to .env.registry and fill in real secrets:
#   cp .env.registry.example .env.registry
#
# This template assumes you run the stack LOCALLY on the target PC and open it
# in a browser on that same machine (http://localhost). For a real server with
# a domain/IP, replace every "localhost" below with that host.

# --- Image tags (override if you pushed a versioned tag instead of latest) ---
BACKEND_TAG=latest
FRONTEND_TAG=latest

# --- Postgres (compose-internal; not published to the host) ---
POSTGRES_DB=lms
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Backend connects to Postgres by service name on the compose network.
DATABASE_URL=postgresql+asyncpg://lms_user:CHANGE_ME_strong_db_password@postgres:5432/lms

# --- JWT ---
# Generate a long random secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_long_random_secret_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Minio ---
# MINIO_ENDPOINT: internal address the backend uses (service name on the network).
# MINIO_PUBLIC_ENDPOINT: address the BROWSER uses for presigned download URLs.
#   For local use this is localhost:9000 (Minio's S3 port is published below).
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_user
MINIO_SECRET_KEY=CHANGE_ME_minio_password
MINIO_BUCKET=lms-files
MINIO_SECURE=false

# --- CORS ---
# The browser origin that may call the API. The nginx frontend serves the app
# and proxies /api same-origin, so this is the site's own URL.
# FRONTEND_PORT=80 below -> origin is http://localhost (no :80 needed).
CORS_ORIGINS=http://localhost

# --- App ---
DEBUG=false

# --- Host port the frontend (nginx) is published on ---
# If 80 is taken on the target PC, set e.g. 8080 and open http://localhost:8080
# (then also update CORS_ORIGINS to match, e.g. http://localhost:8080).
FRONTEND_PORT=80
