# Production environment template. Copy to .env.prod and fill in real values.
#   cp .env.prod.example .env.prod

# --- Postgres (compose-internal; not published to the host) ---
POSTGRES_DB=lms
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Backend connects to Postgres by service name on the compose network.
DATABASE_URL=postgresql+asyncpg://lms_user:CHANGE_ME_strong_db_password@postgres:5432/lms

# --- JWT ---
# Generate a long random secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_long_random_secret_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Minio ---
# MINIO_ENDPOINT: internal address the backend uses (service name on the network).
# MINIO_PUBLIC_ENDPOINT: address the BROWSER uses to download presigned URLs.
#   Must be reachable from clients and match how Minio's S3 port is published.
#   For a real deployment put your domain/IP here, e.g. files.example.com:9000.
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=CHANGE_ME_public_host:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_user
MINIO_SECRET_KEY=CHANGE_ME_minio_password
MINIO_BUCKET=lms-files
MINIO_SECURE=false

# --- CORS ---
# The browser origin(s) that may call the API. With the nginx frontend serving
# same-origin /api this can be the site's own URL. Comma-separated for several.
CORS_ORIGINS=https://CHANGE_ME_your_domain

# --- App ---
DEBUG=false

# --- Host port the frontend (nginx) is published on ---
FRONTEND_PORT=80
